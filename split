#!/bin/bash
# Split a track into 4 keeper stems and drop them in a stems/ folder beside the source.
#   vocals  <- Mel-Band Roformer (the good one)
#   drums   <- htdemucs_ft
#   bass    <- htdemucs_ft
#   other   <- htdemucs_ft  (synths / pads / ambience)
# Discards the Roformer instrumental and the ft vocals.
# Both models run in parallel on MPS (~13% faster than sequential, measured).
#
# Usage:  split /path/to/recording.wav

IN="$1"

if [ "$IN" = "-h" ] || [ "$IN" = "--help" ]; then
  cat << 'HELP'
stems - split a track into 4 stems

usage: stems <audiofile>

  vocals  <- Mel-Band Roformer (best vocals)
  drums   <- htdemucs_ft
  bass    <- htdemucs_ft
  other   <- htdemucs_ft  (synths / pads / ambience)

Both models run in parallel. Stems are written to a stems/<trackname>/
folder beside the source file. Takes wav, mp3, flac, m4a - anything
ffmpeg reads. ~5 min for a 4-min track.
HELP
  exit 0
fi

[ -z "$IN" ] && { echo "usage: stems <audiofile>   (stems --help for details)"; exit 1; }
[ -f "$IN" ] || { echo "not found: $IN"; exit 1; }

# resolve source paths to absolute BEFORE we cd into the tool dir
SRCDIR="$(cd "$(dirname "$IN")" && pwd)"
FILE="$(basename "$IN")"
BASE="${FILE%.*}"
IN_ABS="$SRCDIR/$FILE"
STEMDIR="$SRCDIR/stems/$BASE"

LAB="/Users/marcello/Documents/Development/personal/stem-lab"

# ---------------------------------------------------------------- ui helpers
if [ -t 1 ] && [ -z "$NO_COLOR" ]; then
  FANCY=1
  BOLD=$'\033[1m'; DIM=$'\033[2m'; CYAN=$'\033[36m'; GREEN=$'\033[32m'; RED=$'\033[31m'; RST=$'\033[0m'
else
  FANCY=0
  BOLD=""; DIM=""; CYAN=""; GREEN=""; RED=""; RST=""
fi

SPIN=(в ‹ в ™ в № в ё в ј в ґ в ¦ в § в ‡ в Џ)
RF_PID=""; FT_PID=""

die() { printf '%sвњ— %s%s\n' "$RED" "$1" "$RST" >&2; exit 1; }

fmt_mmss() { printf '%d:%02d' "$(($1 / 60))" "$(($1 % 60))"; }

draw_bar() {
  local n=$(($1 * $2 / 100)) s="" k
  for ((k = 0; k < $2; k++)); do
    if ((k < n)); then s+="в–€"; else s+="в–‘"; fi
  done
  printf '%s' "$s"
}

# Read a tool log and reduce it to: <bars-started> <pct-of-current-bar> <phase> <eta>
# Both audio-separator and demucs emit tqdm bars; demucs runs 4 (bag of 4 models).
snap() {
  LC_ALL=C tr '\r' '\n' < "$1" 2>/dev/null | LC_ALL=C awk '
    BEGIN { starts = 0; pct = 0; phase = "load"; rem = "-" }
    /\[00:00<\?/     { starts++ }
    /^ *[0-9]+%\|/   { p = $0; sub(/%.*/, "", p); gsub(/ /, "", p); pct = p + 0; phase = "sep"
                       if (match($0, /<[0-9:]+,/)) rem = substr($0, RSTART + 1, RLENGTH - 2) }
    /Saving .* stem/ { phase = "write" }
    END { print starts, pct, phase, rem }
  '
}

# stage_line <state:run|ok|fail> <frame> <label> <nmodels> <log> <secs>
stage_line() {
  local state="$1" frame="$2" label="$3" nmodels="$4" log="$5" secs="$6"
  local starts pct phase rem overall info
  case "$state" in
    ok)
      printf '  %sвњ“%s %-17s в–•%sв–Џ 100%%  %sdone in %s%s' \
        "$GREEN" "$RST" "$label" "$(draw_bar 100 24)" "$DIM" "$(fmt_mmss "$secs")" "$RST"
      return ;;
    fail)
      printf '  %sвњ— %-17s failed after %s%s' "$RED" "$label" "$(fmt_mmss "$secs")" "$RST"
      return ;;
  esac
  read -r starts pct phase rem <<< "$(snap "$log")"
  if [ "${starts:-0}" -eq 0 ]; then
    overall=0
    info="loading model"
  else
    overall=$(( ((starts - 1) * 100 + pct) / nmodels ))
    [ "$overall" -gt 100 ] && overall=100
    case "$phase" in
      write) info="writing stems" ;;
      *)     info="separating" ;;
    esac
    [ "$nmodels" -gt 1 ] && info="$info В· model $starts/$nmodels"
    [ "$rem" != "-" ] && [ "$phase" = "sep" ] && info="$info В· eta $rem"
  fi
  printf '  %s%s%s %-17s %sв–•%sв–Џ%s %3d%%  %s%s В· %s%s' \
    "$CYAN" "$frame" "$RST" "$label" "$CYAN" "$(draw_bar "$overall" 24)" "$RST" \
    "$overall" "$DIM" "$info" "$(fmt_mmss "$secs")" "$RST"
}

cleanup_interrupt() {
  [ -n "$RF_PID" ] && kill "$RF_PID" 2>/dev/null
  [ -n "$FT_PID" ] && kill "$FT_PID" 2>/dev/null
  [ "$FANCY" = 1 ] && { printf '\r\033[K'; tput cnorm 2>/dev/null; }
  echo "interrupted"
  exit 130
}
trap cleanup_interrupt INT TERM
trap '[ "$FANCY" = 1 ] && tput cnorm 2>/dev/null' EXIT

# -------------------------------------------------------------------- header
printf '%sstems%s %sВ· roformer vocals в€Ґ htdemucs_ft drums/bass/other%s\n' "$BOLD" "$RST" "$DIM" "$RST"

TRACK_META=""
DUR=""
if command -v ffprobe >/dev/null 2>&1; then
  PROBE="$(ffprobe -v error -select_streams a:0 \
    -show_entries stream=sample_rate,channels -show_entries format=duration \
    -of csv=p=0 "$IN_ABS" 2>/dev/null)"
  SR="$(printf '%s\n' "$PROBE" | sed -n 1p | cut -d, -f1)"
  CH="$(printf '%s\n' "$PROBE" | sed -n 1p | cut -d, -f2)"
  DUR="$(printf '%s\n' "$PROBE" | sed -n 2p | cut -d. -f1)"
  case "$CH" in 1) CHTXT="mono" ;; 2) CHTXT="stereo" ;; *) CHTXT="${CH}ch" ;; esac
  KHZ="$(awk -v s="$SR" 'BEGIN { printf "%g", s / 1000 }')"
  SIZE="$(du -h "$IN_ABS" | cut -f1 | tr -d ' ')"
  [ -n "$DUR" ] && TRACK_META=" ${DIM}В· $(fmt_mmss "$DUR") В· ${KHZ} kHz $CHTXT В· $SIZE$RST"
fi

printf '  %strack%s   %s%s\n' "$DIM" "$RST" "$FILE" "$TRACK_META"
printf '  %soutput%s  %s\n' "$DIM" "$RST" "$STEMDIR"
[ -n "$DUR" ] && printf '  %sest%s     ~%s\n' "$DIM" "$RST" "$(fmt_mmss $((DUR * 3 / 2)))"
echo

cd "$LAB" || die "stem-lab dir not found: $LAB"
mkdir -p "$STEMDIR"
rm -rf _work_rf _work_ft
mkdir -p _work_rf _work_ft
T0=$SECONDS

# ------------------------------------------------- launch both stages at once
RF_LOG="$LAB/.last_rf.log"
FT_LOG="$LAB/.last_ft.log"

.venv/bin/audio-separator "$IN_ABS" -m vocals_mel_band_roformer.ckpt \
  --mdxc_batch_size 4 --output_dir _work_rf --output_format WAV \
  > "$RF_LOG" 2>&1 &
RF_PID=$!

.venv/bin/python -m demucs -d mps -n htdemucs_ft -o _work_ft "$IN_ABS" \
  > "$FT_LOG" 2>&1 &
FT_PID=$!

[ "$FANCY" = 1 ] && { tput civis 2>/dev/null; printf '\n\n'; }

RF_DONE=""; RF_RC=0; RF_T=0; RF_STATE="run"
FT_DONE=""; FT_RC=0; FT_T=0; FT_STATE="run"
i=0
while :; do
  if [ -z "$RF_DONE" ] && ! kill -0 "$RF_PID" 2>/dev/null; then
    wait "$RF_PID"; RF_RC=$?; RF_DONE=1; RF_T=$((SECONDS - T0))
    if [ "$RF_RC" -eq 0 ]; then RF_STATE="ok"; else RF_STATE="fail"; kill "$FT_PID" 2>/dev/null; fi
    [ "$FANCY" = 0 ] && printf '[vocals] %s (%s)\n' "$RF_STATE" "$(fmt_mmss "$RF_T")"
  fi
  if [ -z "$FT_DONE" ] && ! kill -0 "$FT_PID" 2>/dev/null; then
    wait "$FT_PID"; FT_RC=$?; FT_DONE=1; FT_T=$((SECONDS - T0))
    if [ "$FT_RC" -eq 0 ]; then FT_STATE="ok"; else FT_STATE="fail"; kill "$RF_PID" 2>/dev/null; fi
    [ "$FANCY" = 0 ] && printf '[drums/bass/other] %s (%s)\n' "$FT_STATE" "$(fmt_mmss "$FT_T")"
  fi

  if [ "$FANCY" = 1 ]; then
    if [ -n "$RF_DONE" ]; then rf_secs=$RF_T; else rf_secs=$((SECONDS - T0)); fi
    if [ -n "$FT_DONE" ]; then ft_secs=$FT_T; else ft_secs=$((SECONDS - T0)); fi
    L1="$(stage_line "$RF_STATE" "${SPIN[$((i % 10))]}" "vocals" 1 "$RF_LOG" "$rf_secs")"
    L2="$(stage_line "$FT_STATE" "${SPIN[$((i % 10))]}" "drums/bass/other" 4 "$FT_LOG" "$ft_secs")"
    printf '\033[2A\r%s\033[K\n%s\033[K\n' "$L1" "$L2"
  fi

  [ -n "$RF_DONE" ] && [ -n "$FT_DONE" ] && break
  i=$((i + 1))
  sleep 0.25
done

[ "$FANCY" = 1 ] && tput cnorm 2>/dev/null

if [ "$RF_RC" -ne 0 ] && [ "$RF_STATE" = "fail" ]; then
  printf '\n%sвњ— roformer failed%s (exit %d) вЂ” last lines of %s:\n' "$RED" "$RST" "$RF_RC" "$RF_LOG"
  tail -n 12 "$RF_LOG" | sed 's/^/    /'
  exit 1
fi
if [ "$FT_RC" -ne 0 ] && [ "$FT_STATE" = "fail" ]; then
  printf '\n%sвњ— demucs failed%s (exit %d) вЂ” last lines of %s:\n' "$RED" "$RST" "$FT_RC" "$FT_LOG"
  tail -n 12 "$FT_LOG" | sed 's/^/    /'
  exit 1
fi

# ------------------------------------------------------------- collect stems
cp "_work_rf/${BASE}_(vocals)_vocals_mel_band_roformer.wav" "$STEMDIR/vocals.wav" \
  || die "roformer vocals output not found in _work_rf/"
for s in drums bass other; do
  cp "_work_ft/htdemucs_ft/${BASE}/$s.wav" "$STEMDIR/$s.wav" \
    || die "demucs $s output not found in _work_ft/"
done

rm -rf _work_rf _work_ft

echo
printf '%sвњ“ done in %s%s %sв†’%s %s\n' "$GREEN" "$(fmt_mmss $((SECONDS - T0)))" "$RST" "$DIM" "$RST" "$STEMDIR"
for s in vocals drums bass other; do
  SZ="$(du -h "$STEMDIR/$s.wav" | cut -f1 | tr -d ' ')"
  printf '    %s%-11s%s %s%s%s\n' "$BOLD" "$s.wav" "$RST" "$DIM" "$SZ" "$RST"
done
